# 1 — LLM provider (one required). Auto-detected: Anthropic -> OpenAI -> local Ollama.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# 2 — Coding agent — Claude Code, Codex, OpenCode, Cursor Agent, and Aider all use their
#     own local CLI login. Nothing to set here.

# 3 — Optional plugins (all off unless set)
TAVILY_API_KEY=
LINEAR_API_KEY=
LINEAR_TEAM_ID=
NOTIFY_WEBHOOK_URL=

# Demo mode — run the full loop with synthetic turns, no live provider/agent calls.
SONIC_DEMO=0
